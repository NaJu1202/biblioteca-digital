# URL do banco de dados SQLite
DATABASE_URL="file:./prisma/dev.db"

# Chave secreta para assinar os JWT (use uma string longa e aleatória em produção)
JWT_SECRET="troque_por_uma_chave_segura_em_producao"

# Tempo de expiração do JWT (ex: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"

# Porta do servidor
PORT=3000
